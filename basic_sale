        <div class="channel-body">
          <div class="price-row">
            <span class="price-main">309,000원</span>
            <span class="price-discount">43% 할인</span>
            <span class="price-net">실수령 185,400원</span>
          </div>
          <div class="detail-grid">
            <div class="detail-item">
